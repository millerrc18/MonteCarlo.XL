<UserControl x:Class="MonteCarlo.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:MonteCarlo.UI.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">

                <!-- Header -->
                <TextBlock Text="SETTINGS"
                           Style="{StaticResource HeadlineSmall}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,16"/>

                <!-- Theme section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Theme" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>

                        <StackPanel>
                            <RadioButton x:Name="LightRadio"
                                         Content="Light"
                                         GroupName="Theme"
                                         Margin="0,0,0,6"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="13"
                                         Checked="OnThemeChanged"/>
                            <RadioButton x:Name="DarkRadio"
                                         Content="Dark"
                                         GroupName="Theme"
                                         Margin="0,0,0,6"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="13"
                                         Checked="OnThemeChanged"/>
                            <RadioButton x:Name="SystemRadio"
                                         Content="System (auto-detect)"
                                         GroupName="Theme"
                                         Margin="0,0,0,0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="13"
                                         Checked="OnThemeChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Scope section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Settings scope"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,12"/>

                        <RadioButton x:Name="GlobalScopeRadio"
                                     Content="Windows user defaults"
                                     GroupName="SettingsScope"
                                     Margin="0,0,0,6"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource DefaultFont}"
                                     FontSize="13"
                                     Checked="OnSettingsScopeChanged"/>
                        <RadioButton x:Name="WorkbookScopeRadio"
                                     Content="Current workbook overrides"
                                     GroupName="SettingsScope"
                                     Margin="0,0,0,8"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource DefaultFont}"
                                     FontSize="13"
                                     Checked="OnSettingsScopeChanged"/>
                        <TextBlock x:Name="SettingsScopeSummaryText"
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Simulation defaults section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Simulation defaults"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Default run preset" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="DefaultRunPresetComboBox"
                                  Margin="0,0,0,4"
                                  Padding="8,6"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="OnDefaultRunPresetChanged"/>
                        <TextBlock Text="Choose a preset, or type a custom iteration count below."
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Default iterations" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <TextBox x:Name="DefaultIterationsTextBox"
                                 Margin="0,0,0,10"
                                 Padding="8,6"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 TextChanged="OnDefaultIterationsChanged"/>

                        <TextBlock Text="Seed mode" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                        <RadioButton x:Name="RandomSeedRadio"
                                     Content="Random seed for each run"
                                     GroupName="SeedMode"
                                     Margin="0,0,0,6"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource DefaultFont}"
                                     FontSize="13"
                                     Checked="OnSeedModeChanged"/>
                        <RadioButton x:Name="FixedSeedRadio"
                                     Content="Fixed seed by default"
                                     GroupName="SeedMode"
                                     Margin="0,0,0,6"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource DefaultFont}"
                                     FontSize="13"
                                     Checked="OnSeedModeChanged"/>
                        <RadioButton x:Name="PromptSeedRadio"
                                     Content="Prompt for random or fixed seed at run time"
                                     GroupName="SeedMode"
                                     Margin="0,0,0,6"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource DefaultFont}"
                                     FontSize="13"
                                     Checked="OnSeedModeChanged"/>
                        <TextBlock Text="Fixed seed value"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="FixedSeedTextBox"
                                 Margin="18,0,0,10"
                                 Padding="8,6"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"/>
                        <TextBlock Text="Used for Fixed mode and as the default suggestion when Prompt mode is selected."
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="18,0,0,10"/>

                        <TextBlock Text="Sampling method" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SamplingMethodComboBox"
                                  Margin="0,0,0,10"
                                  Padding="8,6"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>

                        <CheckBox x:Name="AutoStopOnConvergenceCheckBox"
                                  Content="Auto-stop when convergence is detected"
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>

                        <TextBlock Text="Excel execution during runs" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ExcelCalculationBehaviorComboBox"
                                  Margin="0,0,0,10"
                                  Padding="8,6"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>

                        <CheckBox x:Name="SuspendScreenUpdatingCheckBox"
                                  Content="Suspend screen updating during runs"
                                  Margin="0,0,0,6"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>

                        <CheckBox x:Name="SuspendEventsCheckBox"
                                  Content="Suspend Excel events during runs"
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>
                        <TextBlock Text="These settings are restored after the run completes or fails."
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <CheckBox x:Name="PauseOnPreflightWarningsCheckBox"
                                  Content="Pause before running when Model Check finds warnings"
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>

                        <TextBlock Text="Default percentiles" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <TextBox x:Name="DefaultPercentilesTextBox"
                                 Margin="0,0,0,8"
                                 Padding="8,6"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"/>
                        <TextBlock Text="Comma-separated values used as the report-builder default list."
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Export section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Results export"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,12"/>

                        <CheckBox x:Name="CreateNewExportSheetCheckBox"
                                  Content="Create a new worksheet for each export"
                                  Margin="0,0,0,6"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>
                        <TextBlock Text="Keeps prior result summaries instead of replacing the existing export sheet."
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SettingsSavedText"
                                       Grid.Column="0"
                                       Style="{StaticResource CaptionText}"
                                       Foreground="{StaticResource Emerald500Brush}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="ClearWorkbookOverridesButton"
                                    Grid.Column="1"
                                    Content="Clear Workbook Overrides"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OnClearWorkbookOverridesClicked"
                                    Padding="12,6"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="SaveSettingsButton"
                                    Grid.Column="2"
                                    Content="Save Defaults"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="OnSaveDefaultsClicked"
                                    Padding="12,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- About section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="About"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="MonteCarlo.XL"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Free Monte Carlo simulation for Excel"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
