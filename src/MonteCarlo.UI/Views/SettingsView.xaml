<UserControl x:Class="MonteCarlo.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:MonteCarlo.UI.Services">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">

                <!-- Header -->
                <TextBlock Text="SETTINGS"
                           Style="{StaticResource HeadlineSmall}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,16"/>

                <!-- Theme section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Theme" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>

                        <StackPanel>
                            <RadioButton x:Name="LightRadio"
                                         Content="Light"
                                         GroupName="Theme"
                                         Margin="0,0,0,6"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="13"
                                         Checked="OnThemeChanged"/>
                            <RadioButton x:Name="DarkRadio"
                                         Content="Dark"
                                         GroupName="Theme"
                                         Margin="0,0,0,6"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="13"
                                         Checked="OnThemeChanged"/>
                            <RadioButton x:Name="SystemRadio"
                                         Content="System (auto-detect)"
                                         GroupName="Theme"
                                         Margin="0,0,0,0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="13"
                                         Checked="OnThemeChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- About section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="About"
                                   Style="{StaticResource HeadlineSmall}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="MonteCarlo.XL"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Free Monte Carlo simulation for Excel"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
