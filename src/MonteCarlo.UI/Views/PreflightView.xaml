<UserControl x:Class="MonteCarlo.UI.Views.PreflightView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:validation="clr-namespace:MonteCarlo.Engine.Validation;assembly=MonteCarlo.Engine">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">
                <TextBlock Text="MODEL CHECK"
                           Style="{StaticResource HeadlineSmall}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,16"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding Summary}"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <UniformGrid Rows="1" Columns="3">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource Red500Brush}"/>
                                <TextBlock Text="Errors" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding WarningCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource Amber500Brush}"/>
                                <TextBlock Text="Warnings" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding InfoCount}"
                                           Style="{StaticResource StatValue}"
                                           Foreground="{StaticResource Blue500Brush}"/>
                                <TextBlock Text="Info" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Issues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,8"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static validation:PreflightSeverity.Error}">
                                                <Setter Property="BorderBrush" Value="{StaticResource Red500Brush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static validation:PreflightSeverity.Warning}">
                                                <Setter Property="BorderBrush" Value="{StaticResource Amber500Brush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static validation:PreflightSeverity.Info}">
                                                <Setter Property="BorderBrush" Value="{StaticResource Blue500Brush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource HeadlineSmall}"
                                                   FontSize="13"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Severity}"
                                                   Style="{StaticResource CaptionText}"
                                                   FontWeight="SemiBold"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Message}"
                                               Style="{StaticResource BodyText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SuggestedAction}"
                                               Style="{StaticResource CaptionText}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Back to Setup"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BackToSetupCommand}"
                            Padding="12,8"/>

                    <Button Grid.Column="2"
                            Content="Run Simulation"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunAnywayCommand}"
                            IsEnabled="{Binding CanRunAnyway}"
                            Padding="16,8"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
