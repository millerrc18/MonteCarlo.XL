<UserControl x:Class="MonteCarlo.UI.Views.InputEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonteCarlo.UI.Views"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
            <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>
            <Style x:Key="FieldInput" TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource Card}" Margin="0,0,0,8"
            BorderBrush="{StaticResource Blue500Brush}" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="NEW INPUT"
                       Style="{StaticResource HeadlineSmall}"
                       Foreground="{StaticResource Blue500Brush}"
                       Margin="0,0,0,12"/>

            <!-- Cell selection -->
            <TextBlock Text="Cell" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NewInputCellAddress, Mode=TwoWay}"
                         IsReadOnly="True"
                         Style="{StaticResource FieldInput}"
                         Margin="0"/>
                <Button Grid.Column="1"
                        Content="&#x1F4CC;"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding StartCellSelectionCommand}"
                        Padding="8,6"
                        Margin="4,0,0,0"
                        ToolTip="Click to select a cell in Excel"/>
            </Grid>

            <!-- Cell selection active indicator -->
            <TextBlock Text="Click a cell in Excel..."
                       Style="{StaticResource BodyText}"
                       Foreground="{StaticResource Blue500Brush}"
                       FontStyle="Italic"
                       Margin="0,0,0,8"
                       Visibility="{Binding IsSelectingCell, Converter={StaticResource BoolVis}}"/>

            <!-- Label -->
            <TextBlock Text="Label" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding NewInputLabel, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FieldInput}"/>

            <!-- Distribution picker -->
            <TextBlock Text="Distribution" Style="{StaticResource FieldLabel}"/>
            <ComboBox ItemsSource="{Binding AvailableDistributions}"
                      SelectedItem="{Binding SelectedDistribution}"
                      Margin="0,0,0,8"
                      Padding="8,6"
                      FontFamily="{StaticResource DefaultFont}"
                      FontSize="13"/>

            <!-- Dynamic parameter fields -->
            <views:DistributionParameterPanel DataContext="{Binding}"/>

            <!-- Distribution preview -->
            <views:DistributionPreviewControl Points="{Binding EditorPreviewPoints}"
                                              Margin="0,4,0,8"
                                              Height="50"
                                              HorizontalAlignment="Stretch"/>

            <!-- Update preview button (hidden — parameters auto-update via binding) -->
            <!-- But we need a way to trigger it since PropertyChanged on individual params
                 doesn't auto-call UpdateEditorPreview. We use a TextChanged approach in code-behind. -->

            <!-- Validation error -->
            <TextBlock Text="{Binding InputValidationError}"
                       Foreground="{StaticResource Red500Brush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       Visibility="{Binding InputValidationError, Converter={StaticResource NullToCollapsed}}"/>

            <!-- Action buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelAddInputCommand}"
                        Padding="12,6"/>
                <Button Grid.Column="3"
                        Content="Add Input"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ConfirmAddInputCommand}"
                        Padding="12,6"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
