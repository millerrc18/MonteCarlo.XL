<UserControl x:Class="MonteCarlo.UI.Views.StatsPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Mean / StdDev -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mean"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MeanFormatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="3" Text="Std Dev"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding StdDevFormatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <!-- Row 2: P5 / P95 -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="P5"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding P5Formatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="3" Text="P95"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding P95Formatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <!-- Row 4: Min / Max -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Min"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MinFormatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="3" Text="Max"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding MaxFormatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <!-- Row 6: Skewness / Kurtosis -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Skew"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SkewnessFormatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="6" Grid.Column="3" Text="Kurt"
                       Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="6" Grid.Column="4" Text="{Binding KurtosisFormatted}"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MonoFont}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
