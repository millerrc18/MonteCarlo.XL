<UserControl x:Class="MonteCarlo.UI.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MonteCarlo.UI.ViewModels"
             xmlns:views="clr-namespace:MonteCarlo.UI.Views"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
            <conv:CountToVisibilityConverter x:Key="CountToVisibility"/>
            <Style x:Key="ManagerDataGrid" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="CanUserReorderColumns" Value="False"/>
                <Setter Property="CanUserSortColumns" Value="True"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceHoverBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
            <Style x:Key="ManagerLabelEditor" TargetType="TextBox">
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:SetupViewModel/>
    </UserControl.DataContext>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">

                <!-- === HEADER === -->
                <TextBlock Text="SIMULATION SETUP"
                           Style="{StaticResource HeadlineSmall}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,16"/>

                <!-- === ITERATION CONFIG === -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Run preset" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding RunPresets}"
                                  SelectedItem="{Binding SelectedRunPreset}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="8,6"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedRunPreset.Description}"
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Iterations" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding IterationPresets}"
                                  SelectedItem="{Binding IterationCount}"
                                  IsEditable="True"
                                  Text="{Binding IterationCount, UpdateSourceTrigger=PropertyChanged}"
                                  Padding="8,6"
                                  FontFamily="{StaticResource MonoFont}"
                                  FontSize="13"
                                  Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Seed" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RandomSeed, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                         IsEnabled="{Binding IsSeedLocked}"
                                         Padding="8,6"
                                         FontFamily="{StaticResource MonoFont}"
                                         FontSize="13"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding ToggleSeedLockCommand}"
                                    VerticalAlignment="Bottom"
                                    Margin="8,0,0,0"
                                    Padding="8,6"
                                    ToolTip="Lock seed for reproducible results">
                                <TextBlock FontSize="16" Text="&#x1F512;"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- === INPUTS SECTION === -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="INPUTS"
                               Style="{StaticResource HeadlineSmall}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ Add"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ShowAddInputCommand}"
                            Foreground="{StaticResource Blue500Brush}"
                            FontWeight="SemiBold"
                            Padding="8,4"/>
                </Grid>

                <!-- Input editor (inline, shown when adding) -->
                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsAddingInput, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="DISTRIBUTION HELPER"
                                   Style="{StaticResource HeadlineSmall}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="What kind of uncertainty is this?"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding DistributionSuggestionCategories}"
                                      SelectedItem="{Binding SelectedDistributionSuggestionCategory}"
                                      Padding="8,6"
                                      FontFamily="{StaticResource DefaultFont}"
                                      FontSize="13"/>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding DistributionSuggestionComplexities}"
                                      SelectedItem="{Binding SelectedDistributionSuggestionComplexity}"
                                      Padding="8,6"
                                      FontFamily="{StaticResource DefaultFont}"
                                      FontSize="13"/>
                        </Grid>

                        <TextBlock Text="Search" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DistributionSuggestionSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"
                                 Padding="8,6"
                                 FontFamily="{StaticResource DefaultFont}"
                                 FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"/>

                        <ComboBox ItemsSource="{Binding FilteredDistributionSuggestions}"
                                  SelectedItem="{Binding SelectedDistributionSuggestion}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0,0,0,4"
                                  Padding="8,6"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>
                        <TextBlock Text="{Binding DistributionSuggestionStatus}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SelectedDistributionSuggestion.HelperSummary}"
                                   Style="{StaticResource CaptionText}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedDistributionSuggestion.UseCase}"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedDistributionSuggestion.ParameterHint}"
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <Button Content="Use This Starting Point"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ApplyDistributionSuggestionCommand}"
                                HorizontalAlignment="Left"
                                Padding="10,6"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Margin="0,12,0,0"
                                Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Fit from historical Excel data"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding DistributionFitResults}"
                                              SelectedItem="{Binding SelectedDistributionFitResult}"
                                              DisplayMemberPath="DisplayName"
                                              Padding="8,6"
                                              FontFamily="{StaticResource DefaultFont}"
                                              FontSize="13"/>
                                    <Button Grid.Column="2"
                                            Content="Select Range"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RequestDistributionFitCommand}"
                                            Padding="10,6"/>
                                </Grid>
                                <TextBlock Text="{Binding SelectedDistributionFitResult.ParameterSummary}"
                                           Style="{StaticResource CaptionText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"
                                           Visibility="{Binding SelectedDistributionFitResult, Converter={StaticResource NullToCollapsed}}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DistributionFitStatus}"
                                               Style="{StaticResource CaptionText}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding DistributionFitStatus, Converter={StaticResource NullToCollapsed}}"/>
                                    <Button Grid.Column="1"
                                            Content="Use Fit"
                                            Style="{StaticResource GhostButton}"
                                            Command="{Binding ApplyDistributionFitCommand}"
                                            Padding="8,4"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <views:InputEditorControl DataContext="{Binding}"
                                          Visibility="{Binding IsAddingInput, Converter={StaticResource BoolVis}}"/>

                <!-- Input cards list -->
                <ItemsControl ItemsSource="{Binding Inputs}"
                              DataContext="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InputCardViewModel}">
                            <views:InputCardControl/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for inputs -->
                <Border Style="{StaticResource Card}"
                        Margin="0,4,0,12"
                        Visibility="{Binding Inputs.Count, Converter={StaticResource CountToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock Text="&#x1F3B2;"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Add your first uncertain input"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a cell in Excel and click + Add above"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,8"/>
                        <Button Content="+ Add Input"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ShowAddInputCommand}"
                                HorizontalAlignment="Center"
                                Padding="16,8"/>
                    </StackPanel>
                </Border>

                <!-- Correlation button (visible when 2+ inputs) -->
                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding OpenCorrelationEditorCommand}"
                        HorizontalAlignment="Left"
                        Padding="8,6"
                        Margin="0,0,0,8">
                    <Button.IsEnabled>
                        <Binding Path="CanDefineCorrelations"/>
                    </Button.IsEnabled>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " FontSize="12"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource Blue500Brush}">
                            <Run Text="Define Correlations ("/>
                            <Run Text="{Binding Inputs.Count, Mode=OneWay}"/>
                            <Run Text=" inputs)"/>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- === OUTPUTS SECTION === -->
                <Grid Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="OUTPUTS"
                               Style="{StaticResource HeadlineSmall}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ Add"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ShowAddOutputCommand}"
                            Foreground="{StaticResource Blue500Brush}"
                            FontWeight="SemiBold"
                            Padding="8,4"/>
                </Grid>

                <!-- Output editor (inline) -->
                <Border Visibility="{Binding IsAddingOutput, Converter={StaticResource BoolVis}}"
                        Style="{StaticResource Card}" Margin="0,0,0,8"
                        BorderBrush="{StaticResource Emerald500Brush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="NEW OUTPUT"
                                   Style="{StaticResource HeadlineSmall}"
                                   Foreground="{StaticResource Emerald500Brush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Cell" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewOutputCellAddress, Mode=TwoWay}"
                                     IsReadOnly="True"
                                     Padding="8,6"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="13"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StartOutputCellSelectionCommand}"
                                    Padding="8,6"
                                    Margin="4,0,0,0">
                                <TextBlock Text="&#x1F4CC;"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="Click a cell in Excel..."
                                   Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource Emerald500Brush}"
                                   FontStyle="Italic"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding IsSelectingOutputCell, Converter={StaticResource BoolVis}}"/>

                        <TextBlock Text="Label" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NewOutputLabel, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 FontFamily="{StaticResource DefaultFont}"
                                 FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1"
                                    Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CancelAddOutputCommand}"
                                    Padding="12,6"/>
                            <Button Grid.Column="3"
                                    Content="Add Output"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmAddOutputCommand}"
                                    Padding="12,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Output cards list -->
                <ItemsControl ItemsSource="{Binding Outputs}"
                              DataContext="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:OutputCardViewModel}">
                            <views:OutputCardControl/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for outputs -->
                <Border Style="{StaticResource Card}"
                        Margin="0,4,0,16"
                        Visibility="{Binding Outputs.Count, Converter={StaticResource CountToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock Text="&#x1F4CA;"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Tag an output cell to track"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a formula cell whose result you want to analyze"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,8"/>
                        <Button Content="+ Add Output"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ShowAddOutputCommand}"
                                HorizontalAlignment="Center"
                                Padding="16,8"/>
                    </StackPanel>
                </Border>

                <!-- === MODEL MANAGER === -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MODEL MANAGER"
                                           Style="{StaticResource HeadlineSmall}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="Review, edit, copy, jump to, and repaint configured cells"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{Binding ManagerToggleLabel}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ToggleManagerCommand}"
                                    Padding="10,6"/>
                        </Grid>

                        <StackPanel Visibility="{Binding IsManagerVisible, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Use Jump to activate the source cell in Excel, or Refresh highlights after workbook formatting changes."
                                           Style="{StaticResource CaptionText}"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Column="2"
                                        Content="Refresh Highlights"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding RefreshHighlightsCommand}"
                                        Padding="8,4"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Inputs"
                                           Style="{StaticResource HeadlineSmall}"
                                           Foreground="{StaticResource Blue500Brush}"/>
                                <Button Grid.Column="1"
                                        Content="Clear Inputs"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ClearInputsCommand}"
                                        Padding="8,4"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding InputManagerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="12"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         ToolTip="Filter inputs by label, cell, distribution, parameters, or summary values."/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding InputManagerStatus}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Click column headers to sort. Edit labels directly in the table."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,6"/>

                            <DataGrid ItemsSource="{Binding InputManagerView}"
                                      Style="{StaticResource ManagerDataGrid}"
                                      Margin="0,0,0,14"
                                      MaxHeight="280"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Label"
                                                            SortMemberPath="Label"
                                                            Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource ManagerLabelEditor}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Cell"
                                                        Binding="{Binding FullReference}"
                                                        SortMemberPath="FullReference"
                                                        IsReadOnly="True"
                                                        Width="125"/>
                                    <DataGridTextColumn Header="Distribution"
                                                        Binding="{Binding DistributionName}"
                                                        SortMemberPath="DistributionName"
                                                        IsReadOnly="True"
                                                        Width="105"/>
                                    <DataGridTextColumn Header="Parameters"
                                                        Binding="{Binding ParameterSummary}"
                                                        SortMemberPath="ParameterSummary"
                                                        IsReadOnly="True"
                                                        Width="220"/>
                                    <DataGridTextColumn Header="Mean"
                                                        Binding="{Binding MeanSummary}"
                                                        SortMemberPath="MeanValue"
                                                        IsReadOnly="True"
                                                        Width="80"/>
                                    <DataGridTextColumn Header="P5"
                                                        Binding="{Binding P5Summary}"
                                                        SortMemberPath="P5Value"
                                                        IsReadOnly="True"
                                                        Width="80"/>
                                    <DataGridTextColumn Header="P95"
                                                        Binding="{Binding P95Summary}"
                                                        SortMemberPath="P95Value"
                                                        IsReadOnly="True"
                                                        Width="80"/>
                                    <DataGridTemplateColumn Header="Actions"
                                                            Width="250"
                                                            IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <WrapPanel>
                                                    <Button Content="Jump"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.JumpToInputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Edit"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.EditInputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Copy"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.DuplicateInputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Highlight"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.HighlightInputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Remove"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.RemoveInputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                </WrapPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Margin="0,14,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Outputs"
                                           Style="{StaticResource HeadlineSmall}"
                                           Foreground="{StaticResource Emerald500Brush}"/>
                                <Button Grid.Column="1"
                                        Content="Clear Outputs"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ClearOutputsCommand}"
                                        Padding="8,4"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding OutputManagerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6"
                                         FontFamily="{StaticResource DefaultFont}"
                                         FontSize="12"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         ToolTip="Filter outputs by label or cell."/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding OutputManagerStatus}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Labels can be edited in place here before you run or export."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,6"/>

                            <DataGrid ItemsSource="{Binding OutputManagerView}"
                                      Style="{StaticResource ManagerDataGrid}"
                                      MaxHeight="220"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Label"
                                                            SortMemberPath="Label"
                                                            Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource ManagerLabelEditor}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Cell"
                                                        Binding="{Binding FullReference}"
                                                        SortMemberPath="FullReference"
                                                        IsReadOnly="True"
                                                        Width="150"/>
                                    <DataGridTemplateColumn Header="Actions"
                                                            Width="250"
                                                            IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <WrapPanel>
                                                    <Button Content="Jump"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.JumpToOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Edit"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.EditOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Copy"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.DuplicateOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Highlight"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.HighlightOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Remove"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.RemoveOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                </WrapPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- === MODEL CHECK + RUN BUTTONS === -->
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RunPreflightCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="12,12"
                            FontSize="13">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x2713;" Margin="0,0,6,0"/>
                            <TextBlock Text="Model Check"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunSimulationCommand}"
                            IsEnabled="{Binding CanRun}"
                            HorizontalAlignment="Stretch"
                            Padding="16,12"
                            FontSize="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x25B6;" Margin="0,0,8,0"/>
                            <TextBlock Text="Run Simulation"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
