<UserControl x:Class="MonteCarlo.UI.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MonteCarlo.UI.ViewModels"
             xmlns:views="clr-namespace:MonteCarlo.UI.Views"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
            <conv:CountToVisibilityConverter x:Key="CountToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:SetupViewModel/>
    </UserControl.DataContext>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">

                <!-- === HEADER === -->
                <TextBlock Text="SIMULATION SETUP"
                           Style="{StaticResource HeadlineSmall}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,16"/>

                <!-- === ITERATION CONFIG === -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Iterations" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding IterationPresets}"
                                  SelectedItem="{Binding IterationCount}"
                                  IsEditable="True"
                                  Text="{Binding IterationCount, UpdateSourceTrigger=PropertyChanged}"
                                  Padding="8,6"
                                  FontFamily="{StaticResource MonoFont}"
                                  FontSize="13"
                                  Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Seed" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RandomSeed, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                         IsEnabled="{Binding IsSeedLocked}"
                                         Padding="8,6"
                                         FontFamily="{StaticResource MonoFont}"
                                         FontSize="13"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding ToggleSeedLockCommand}"
                                    VerticalAlignment="Bottom"
                                    Margin="8,0,0,0"
                                    Padding="8,6"
                                    ToolTip="Lock seed for reproducible results">
                                <TextBlock FontSize="16" Text="&#x1F512;"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- === INPUTS SECTION === -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="INPUTS"
                               Style="{StaticResource HeadlineSmall}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ Add"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ShowAddInputCommand}"
                            Foreground="{StaticResource Blue500Brush}"
                            FontWeight="SemiBold"
                            Padding="8,4"/>
                </Grid>

                <!-- Input editor (inline, shown when adding) -->
                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsAddingInput, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="DISTRIBUTION HELPER"
                                   Style="{StaticResource HeadlineSmall}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding DistributionSuggestions}"
                                  SelectedItem="{Binding SelectedDistributionSuggestion}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0,0,0,8"
                                  Padding="8,6"
                                  FontFamily="{StaticResource DefaultFont}"
                                  FontSize="13"/>
                        <TextBlock Text="{Binding SelectedDistributionSuggestion.UseCase}"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedDistributionSuggestion.ParameterHint}"
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <Button Content="Use This Starting Point"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ApplyDistributionSuggestionCommand}"
                                HorizontalAlignment="Left"
                                Padding="10,6"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Margin="0,12,0,0"
                                Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Fit from selected Excel data"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding DistributionFitResults}"
                                              SelectedItem="{Binding SelectedDistributionFitResult}"
                                              DisplayMemberPath="DisplayName"
                                              Padding="8,6"
                                              FontFamily="{StaticResource DefaultFont}"
                                              FontSize="13"/>
                                    <Button Grid.Column="2"
                                            Content="Fit Range"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RequestDistributionFitCommand}"
                                            Padding="10,6"/>
                                </Grid>
                                <TextBlock Text="{Binding SelectedDistributionFitResult.ParameterSummary}"
                                           Style="{StaticResource CaptionText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"
                                           Visibility="{Binding SelectedDistributionFitResult, Converter={StaticResource NullToCollapsed}}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DistributionFitStatus}"
                                               Style="{StaticResource CaptionText}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding DistributionFitStatus, Converter={StaticResource NullToCollapsed}}"/>
                                    <Button Grid.Column="1"
                                            Content="Use Fit"
                                            Style="{StaticResource GhostButton}"
                                            Command="{Binding ApplyDistributionFitCommand}"
                                            Padding="8,4"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <views:InputEditorControl DataContext="{Binding}"
                                          Visibility="{Binding IsAddingInput, Converter={StaticResource BoolVis}}"/>

                <!-- Input cards list -->
                <ItemsControl ItemsSource="{Binding Inputs}"
                              DataContext="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InputCardViewModel}">
                            <views:InputCardControl/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for inputs -->
                <Border Style="{StaticResource Card}"
                        Margin="0,4,0,12"
                        Visibility="{Binding Inputs.Count, Converter={StaticResource CountToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock Text="&#x1F3B2;"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Add your first uncertain input"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a cell in Excel and click + Add above"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,8"/>
                        <Button Content="+ Add Input"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ShowAddInputCommand}"
                                HorizontalAlignment="Center"
                                Padding="16,8"/>
                    </StackPanel>
                </Border>

                <!-- Correlation button (visible when 2+ inputs) -->
                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding OpenCorrelationEditorCommand}"
                        HorizontalAlignment="Left"
                        Padding="8,6"
                        Margin="0,0,0,8">
                    <Button.IsEnabled>
                        <Binding Path="CanDefineCorrelations"/>
                    </Button.IsEnabled>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " FontSize="12"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource Blue500Brush}">
                            <Run Text="Define Correlations ("/>
                            <Run Text="{Binding Inputs.Count, Mode=OneWay}"/>
                            <Run Text=" inputs)"/>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- === OUTPUTS SECTION === -->
                <Grid Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="OUTPUTS"
                               Style="{StaticResource HeadlineSmall}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ Add"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ShowAddOutputCommand}"
                            Foreground="{StaticResource Blue500Brush}"
                            FontWeight="SemiBold"
                            Padding="8,4"/>
                </Grid>

                <!-- Output editor (inline) -->
                <Border Visibility="{Binding IsAddingOutput, Converter={StaticResource BoolVis}}"
                        Style="{StaticResource Card}" Margin="0,0,0,8"
                        BorderBrush="{StaticResource Emerald500Brush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="NEW OUTPUT"
                                   Style="{StaticResource HeadlineSmall}"
                                   Foreground="{StaticResource Emerald500Brush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Cell" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewOutputCellAddress, Mode=TwoWay}"
                                     IsReadOnly="True"
                                     Padding="8,6"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="13"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StartOutputCellSelectionCommand}"
                                    Padding="8,6"
                                    Margin="4,0,0,0">
                                <TextBlock Text="&#x1F4CC;"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="Click a cell in Excel..."
                                   Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource Emerald500Brush}"
                                   FontStyle="Italic"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding IsSelectingOutputCell, Converter={StaticResource BoolVis}}"/>

                        <TextBlock Text="Label" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NewOutputLabel, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 FontFamily="{StaticResource DefaultFont}"
                                 FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1"
                                    Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CancelAddOutputCommand}"
                                    Padding="12,6"/>
                            <Button Grid.Column="3"
                                    Content="Add Output"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmAddOutputCommand}"
                                    Padding="12,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Output cards list -->
                <ItemsControl ItemsSource="{Binding Outputs}"
                              DataContext="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:OutputCardViewModel}">
                            <views:OutputCardControl/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for outputs -->
                <Border Style="{StaticResource Card}"
                        Margin="0,4,0,16"
                        Visibility="{Binding Outputs.Count, Converter={StaticResource CountToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock Text="&#x1F4CA;"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Tag an output cell to track"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a formula cell whose result you want to analyze"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,8"/>
                        <Button Content="+ Add Output"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ShowAddOutputCommand}"
                                HorizontalAlignment="Center"
                                Padding="16,8"/>
                    </StackPanel>
                </Border>

                <!-- === MODEL MANAGER === -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MODEL MANAGER"
                                           Style="{StaticResource HeadlineSmall}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="Review, edit, copy, jump to, and repaint configured cells"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{Binding ManagerToggleLabel}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ToggleManagerCommand}"
                                    Padding="10,6"/>
                        </Grid>

                        <StackPanel Visibility="{Binding IsManagerVisible, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Use Jump to activate the source cell in Excel, or Refresh highlights after workbook formatting changes."
                                           Style="{StaticResource CaptionText}"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Column="2"
                                        Content="Refresh Highlights"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding RefreshHighlightsCommand}"
                                        Padding="8,4"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Inputs"
                                           Style="{StaticResource HeadlineSmall}"
                                           Foreground="{StaticResource Blue500Brush}"/>
                                <Button Grid.Column="1"
                                        Content="Clear Inputs"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ClearInputsCommand}"
                                        Padding="8,4"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Inputs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:InputCardViewModel}">
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Padding="0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Label}"
                                                                   Style="{StaticResource BodyText}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Style="{StaticResource CaptionText}">
                                                            <Run Text="{Binding FullReference}"/>
                                                            <Run Text=" | "/>
                                                            <Run Text="{Binding DistributionName}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <Button Content="Jump"
                                                                Style="{StaticResource GhostButton}"
                                                                Command="{Binding DataContext.JumpToInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="6,3"/>
                                                        <Button Content="Edit"
                                                                Style="{StaticResource GhostButton}"
                                                                Command="{Binding DataContext.EditInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="6,3"/>
                                                        <Button Content="Copy"
                                                                Style="{StaticResource GhostButton}"
                                                                Command="{Binding DataContext.DuplicateInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="6,3"/>
                                                    </WrapPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding ParameterSummary}"
                                                           Style="{StaticResource CaptionText}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Style="{StaticResource CaptionText}" Margin="0,2,0,0">
                                                    <Run Text="Mean "/>
                                                    <Run Text="{Binding MeanSummary}"/>
                                                    <Run Text=" | P5 "/>
                                                    <Run Text="{Binding P5Summary}"/>
                                                    <Run Text=" | P95 "/>
                                                    <Run Text="{Binding P95Summary}"/>
                                                </TextBlock>
                                                <WrapPanel Margin="0,6,0,0">
                                                    <Button Content="Highlight"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.HighlightInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Remove"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.RemoveInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,14,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Outputs"
                                           Style="{StaticResource HeadlineSmall}"
                                           Foreground="{StaticResource Emerald500Brush}"/>
                                <Button Grid.Column="1"
                                        Content="Clear Outputs"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ClearOutputsCommand}"
                                        Padding="8,4"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Outputs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:OutputCardViewModel}">
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Label}"
                                                               Style="{StaticResource BodyText}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding FullReference}"
                                                               Style="{StaticResource CaptionText}"/>
                                                </StackPanel>
                                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <Button Content="Jump"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.JumpToOutputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Edit"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.EditOutputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Copy"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.DuplicateOutputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Highlight"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.HighlightOutputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                    <Button Content="Remove"
                                                            Style="{StaticResource GhostButton}"
                                                            Command="{Binding DataContext.RemoveOutputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,3"/>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- === MODEL CHECK + RUN BUTTONS === -->
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RunPreflightCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="12,12"
                            FontSize="13">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x2713;" Margin="0,0,6,0"/>
                            <TextBlock Text="Model Check"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunSimulationCommand}"
                            IsEnabled="{Binding CanRun}"
                            HorizontalAlignment="Stretch"
                            Padding="16,12"
                            FontSize="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x25B6;" Margin="0,0,8,0"/>
                            <TextBlock Text="Run Simulation"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
