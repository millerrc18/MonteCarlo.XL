<UserControl x:Class="MonteCarlo.UI.Views.TargetLineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource Card}">
        <StackPanel>
            <TextBlock Text="TARGET ANALYSIS"
                       Style="{StaticResource HeadlineSmall}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Target Value" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
            <TextBox Text="{Binding TargetValueText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="13"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Margin="0,0,0,8"/>

            <StackPanel Visibility="{Binding ProbabilityAboveTarget, Converter={StaticResource NullToCollapsed}}">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="P(above target):"
                               Style="{StaticResource BodyText}"
                               Foreground="{StaticResource Emerald500Brush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProbabilityAboveTarget, StringFormat='{}{0:P1}'}"
                               Style="{StaticResource BodyText}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="P(below target):"
                               Style="{StaticResource BodyText}"
                               Foreground="{StaticResource Red500Brush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProbabilityBelowTarget, StringFormat='{}{0:P1}'}"
                               Style="{StaticResource BodyText}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MonoFont}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
