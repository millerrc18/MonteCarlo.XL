<UserControl x:Class="MonteCarlo.UI.Views.DistributionParameterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <conv:DistributionVisibilityConverter x:Key="DistVis"/>
        <Style x:Key="ParamLabel" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="ParamInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Normal parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Normal}">
            <TextBlock Text="Mean (μ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMean, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Std Dev (σ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamStdDev, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Triangular / PERT parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter='Triangular,PERT'}">
            <TextBlock Text="Minimum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMin, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Most Likely (Mode)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMode, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Maximum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMax, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Uniform parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Uniform}">
            <TextBlock Text="Minimum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMin, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Maximum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMax, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Lognormal parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Lognormal}">
            <TextBlock Text="μ (log mean)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMu, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="σ (log std dev)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamSigma, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Discrete parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Discrete}">
            <ItemsControl ItemsSource="{Binding DiscretePairs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamInput}"
                                     Margin="0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding Probability, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamInput}"
                                     Margin="0"/>
                            <Button Grid.Column="3"
                                    Content="✕"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding DataContext.RemoveDiscretePairCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="4,2"
                                    Margin="4,0,0,0"
                                    FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Value" Style="{StaticResource CaptionText}" Margin="0,0,0,0"/>
                <TextBlock Grid.Column="2" Text="Probability" Style="{StaticResource CaptionText}" Margin="0,0,0,0"/>
            </Grid>
            <Button Content="+ Add Row"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding AddDiscretePairCommand}"
                    HorizontalAlignment="Left"
                    Padding="8,4"/>
        </StackPanel>
    </StackPanel>
</UserControl>
