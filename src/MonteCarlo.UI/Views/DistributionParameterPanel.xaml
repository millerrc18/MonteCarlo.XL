<UserControl x:Class="MonteCarlo.UI.Views.DistributionParameterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:DistributionVisibilityConverter x:Key="DistVis"/>
            <Style x:Key="ParamLabel" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>
            <Style x:Key="ParamInput" TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <!-- Normal parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Normal}">
            <TextBlock Text="Mean (μ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMean, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Std Dev (σ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamStdDev, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Triangular / PERT parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter='Triangular,PERT'}">
            <TextBlock Text="Minimum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMin, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Most Likely (Mode)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMode, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Maximum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMax, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Uniform parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Uniform}">
            <TextBlock Text="Minimum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMin, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Maximum" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMax, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Lognormal parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Lognormal}">
            <TextBlock Text="μ (log mean)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMu, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="σ (log std dev)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamSigma, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Beta parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Beta}">
            <TextBlock Text="Alpha (α)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamAlpha, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Beta (β)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamBeta, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Weibull parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Weibull}">
            <TextBlock Text="Shape (k)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamShape, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Scale (λ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamScale, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Exponential parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Exponential}">
            <TextBlock Text="Rate (λ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamRate, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Poisson parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Poisson}">
            <TextBlock Text="Rate (λ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamLambda, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Gamma parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Gamma}">
            <TextBlock Text="Shape (k)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamShape, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Rate (β)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamRateGamma, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Logistic parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Logistic}">
            <TextBlock Text="Location (μ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMu, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Scale (s)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamS, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- GEV parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=GEV}">
            <TextBlock Text="Location (μ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamMu, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Scale (σ)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamSigma, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Shape (ξ)" Style="{StaticResource ParamLabel}"
                       ToolTip="ξ=0 Gumbel, ξ&gt;0 Fréchet, ξ&lt;0 Weibull"/>
            <TextBox Text="{Binding ParamXi, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"
                     ToolTip="ξ=0 Gumbel, ξ&gt;0 Fréchet, ξ&lt;0 Weibull"/>
        </StackPanel>

        <!-- Binomial parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Binomial}">
            <TextBlock Text="Trials (n)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamN, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
            <TextBlock Text="Probability (p)" Style="{StaticResource ParamLabel}"/>
            <TextBox Text="{Binding ParamP, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"/>
        </StackPanel>

        <!-- Geometric parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Geometric}">
            <TextBlock Text="Probability (p)" Style="{StaticResource ParamLabel}"
                       ToolTip="Number of trials until first success"/>
            <TextBox Text="{Binding ParamP, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ParamInput}"
                     ToolTip="Number of trials until first success"/>
        </StackPanel>

        <!-- Discrete parameters -->
        <StackPanel Visibility="{Binding SelectedDistribution, Converter={StaticResource DistVis}, ConverterParameter=Discrete}">
            <ItemsControl ItemsSource="{Binding DiscretePairs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamInput}"
                                     Margin="0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding Probability, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ParamInput}"
                                     Margin="0"/>
                            <Button Grid.Column="3"
                                    Content="✕"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding DataContext.RemoveDiscretePairCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="4,2"
                                    Margin="4,0,0,0"
                                    FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Value" Style="{StaticResource CaptionText}" Margin="0,0,0,0"/>
                <TextBlock Grid.Column="2" Text="Probability" Style="{StaticResource CaptionText}" Margin="0,0,0,0"/>
            </Grid>
            <Button Content="+ Add Row"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding AddDiscretePairCommand}"
                    HorizontalAlignment="Left"
                    Padding="8,4"/>
        </StackPanel>
    </StackPanel>
</UserControl>
