<UserControl x:Class="MonteCarlo.UI.Views.HeadlineStatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Padding="16,20">
        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="{Binding HeadlineValue}"
                       Style="{StaticResource StatValue}"
                       FontSize="28"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding HeadlineLabel}"
                       Style="{StaticResource BodyText}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
            <TextBlock Text="{Binding HeadlineRange}"
                       Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
