<UserControl x:Class="MonteCarlo.UI.Views.CorrelationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonteCarlo.UI.Views"
             xmlns:conv="clr-namespace:MonteCarlo.UI.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/LightTheme.xaml"/>
                <ResourceDictionary Source="/MonteCarlo.UI;component/Styles/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="16,12" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="INPUT CORRELATIONS"
                           Style="{StaticResource HeadlineSmall}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="?"
                        Style="{StaticResource GhostButton}"
                        ToolTip="Enter Spearman rank correlations between -1 and +1. Leave as 0 for independent inputs."
                        Padding="8,4" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom" Padding="16,8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Clear All"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding ClearAllCommand}"
                        Padding="12,6"/>
                <Button Grid.Column="2" Content="Apply &amp; Close"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyCommand}"
                        Padding="16,8"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>
                <!-- Tip -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                    <TextBlock TextWrapping="Wrap"
                               Style="{StaticResource CaptionText}"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="Tip:"/> Enter Spearman rank correlations (-1 to +1).
                        Leave as 0 for independent inputs.
                    </TextBlock>
                </Border>

                <!-- Matrix Grid -->
                <views:CorrelationMatrixGrid x:Name="MatrixGridControl"
                    InputLabels="{Binding InputLabels}"
                    MatrixValues="{Binding MatrixValues}"
                    Margin="0,0,0,12"/>

                <!-- Validation Status -->
                <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#DCFCE7"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Background" Value="#FEF3C7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <Setter Property="Foreground" Value="#166534"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                            <Setter Property="Foreground" Value="#92400E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="1" Content="Auto-fix"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AutoFixCommand}"
                                Visibility="{Binding CanAutoFix, Converter={StaticResource BoolToVis}}"
                                Padding="8,4" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Scroll hint for many inputs -->
                <TextBlock Text="Scroll horizontally to see all inputs."
                           Style="{StaticResource CaptionText}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="10" Margin="0,4,0,0"
                           Visibility="Collapsed"
                           x:Name="ScrollHint"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
